# Alpaca Paper Trading (free at https://alpaca.markets)
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_here


# Trading config
STARTING_CAPITAL=10000
MAX_POSITION_SIZE=0.10
# Crypto symbols trade 24/7; GLD is a stock ETF (NYSE market hours only)
# Crypto format: BTC/USD, ETH/USD  |  Stock/ETF: GLD, AAPL, etc.
SYMBOLS=BTC/USD,ETH/USD,GLD

# Dashboard port
PORT=8080

# MT5-only mode — set to true to hide all Alpaca UI and show only the MT5 Bridge tab
MT5_ONLY=false
